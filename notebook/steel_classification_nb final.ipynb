def find_neu_det_root(search_root="/kaggle/input"):
    for dirpath, dirnames, filenames in os.walk(search_root):
        if os.path.basename(dirpath) == "NEU-DET":
            return dirpath
    raise FileNotFoundError(
        "Could not find a folder named 'NEU-DET' under /kaggle/input. "
        "Make sure you attached the NEU-DET dataset via 'Add Data'."
    )

