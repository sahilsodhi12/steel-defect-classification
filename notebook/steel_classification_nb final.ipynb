def collect_images(split):
    rows = []
    images_root = os.path.join(NEU_ROOT, split, "images")
    for cls in CLASS_NAMES:
        cls_dir = os.path.join(images_root, cls)
        for fp in glob.glob(os.path.join(cls_dir, "*.jpg")) + glob.glob(os.path.join(cls_dir, "*.png")):
            rows.append({"filepath": fp, "label": cls})
    return pd.DataFrame(rows)

